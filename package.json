{
  "name": "mblog-front",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host=127.0.0.1 --port=3333",
    "devallinone": "vite --host=127.0.0.1 --port=3333 --mode=all",
    "build": "pnpm run type-check && pnpm run build-only",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "build-cf": "sh ./cf.sh"
  },
  "dependencies": {
    "@vueuse/core": "^10.11.1",
    "@vueuse/integrations": "^10.11.1",
    "@vueuse/motion": "^2.2.6",
    "axios": "^1.13.6",
    "dayjs": "^1.11.19",
    "drauu": "^0.3.7",
    "emoji-picker-element": "^1.29.1",
    "marked": "^5.1.2",
    "marked-gfm-heading-id": "^3.2.0",
    "marked-mangle": "^1.1.12",
    "pinia": "^2.3.1",
    "vue": "^3.5.29",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@tailwindcss/vite": "^4.2.1",
    "@iconify-json/carbon": "^1.2.19",
    "@tsconfig/node18": "^2.0.1",
    "@types/marked": "^4.3.2",
    "@types/node": "^20.19.35",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.3.2",
    "eslint": "^9.35.0",
    "eslint-plugin-vue": "~10.4.0",
    "naive-ui": "^2.43.2",
    "prettier": "^2.8.8",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.0.4",
    "unplugin-auto-import": "^0.15.3",
    "unplugin-vue-components": "^0.24.1",
    "vite": "^7.3.1",
    "vite-plugin-pages": "^0.29.1",
    "vite-plugin-pwa": "^0.16.7",
    "vite-plugin-vue-layouts": "^0.8.0",
    "vue-tsc": "^1.8.27"
  }
}
